---
import Logo from "./Logo.astro";
---

<header id="navbar" class="py-4 px-10 flex items-center fixed top-0 w-full justify-between z-50 text-white">
    <div class="flex flex-grow basis-0">
        <Logo/>
    </div>

    <nav>
        <ul class="flex text-sm [&>li>a]:transition-colors [&>li>a]:duration-100 [&>li>a]:text-current [&>li>a]:font-medium [&>li>a]:inline-block [&>li>a]:px-4 [&>li>a]:py-2">
            <li><a href="#Home">Home</a></li>
            <li><a href="#About">About</a></li>
            <li><a href="#Project">Project</a></li>
        </ul>
    </nav>

    <nav class="flex flex-grow justify-end basis-0">
        <ul class="flex text-sm [&>li>a]:transition-colors [&>li>a]:duration-100 [&>li>a]:text-current [&>li>a]:font-medium [&>li>a]:inline-block [&>li>a]:px-4 [&>li>a]:py-2">
            <li><a href="#Contact">Contact</a></li>
            <li><a href="#">Menu</a></li>
        </ul>
    </nav>

    <div 
        id="menu-backdrop" 
        class={`
        absolute bg-black/10 backdrop-blur-lg rounded 
        translate-x-[var(--left)] translate-y-[var(--top)]
        left-0 top-0
        w-[var(--width)] h-[var(--height)] 
        transition-all duration-500 
        ease-in-out opacity-0 -z-10
        `}>
    </div>
</header>

<script src="../js/navbarColorDetection.js"></script>
<script src="../js/menuBackDrop.js"></script>